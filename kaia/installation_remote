# Prerequisites to start run.py

- docker
- npm

# Chmod for docker socket

Onetime: chmod 666 /var/run/docker.sock

Permanent:

sudo tee /etc/systemd/system/docker-sock-chmod.service <<EOF
[Unit]
Description=Fix docker.sock permissions
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/bin/chmod 666 /var/run/docker.sock

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable docker-sock-chmod.service

# Caddy

# Server-side

sudo apt update
sudo apt install -y debian-keyring debian-archive-keyring apt-transport-https curl gnupg

# Key
curl -fsSL https://dl.cloudsmith.io/public/caddy/stable/gpg.key \
  | sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg

# Repo
echo "deb [signed-by=/usr/share/keyrings/caddy-stable-archive-keyring.gpg] \
https://dl.cloudsmith.io/public/caddy/stable/deb/ubuntu any-version main" \
| sudo tee /etc/apt/sources.list.d/caddy-stable.list >/dev/null

# Installation
sudo apt update
sudo apt install -y caddy

## Creating config file
sudo tee /etc/caddy/Caddyfile >/dev/null <<EOF
<ID_ADDRESS_OR_HOST>:13003 {
    tls internal
    reverse_proxy 127.0.0.1:13002
}
EOF

## Restart
sudo systemctl restart caddy

## Exporting certificate

sudo cp /var/lib/caddy/.local/share/caddy/pki/authorities/local/root.crt ~/caddy-root.crt
sudo chown $USER:$USER ~/caddy-root.crt

# If you need to change the config:

sudo nano /etc/caddy/Caddyfile

sudo caddy validate --config /etc/caddy/Caddyfile

sudo systemctl reload caddy

No need to change certificate

# Client side

# Download certificate

scp user@SERVER:/path/to/caddy-root.crt ~/caddy-root.crt

# In Firefox
Settings → Privacy & Security
Certificates → View Certificates
Authorities → Import
Find caddy-root.crt
Check "Trust this CA to identify websites"

